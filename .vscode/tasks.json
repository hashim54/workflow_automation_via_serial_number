{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Create venv (Python 3.12)",
            "type": "shell",
            "command": "py -3.12 -m venv \"${workspaceFolder}\\backend\\.venv\"",
            "windows": {
                "command": "py -3.12 -m venv \"${workspaceFolder}\\backend\\.venv\""
            },
            "osx": {
                "command": "python3.12 -m venv ${workspaceFolder}/backend/.venv"
            },
            "linux": {
                "command": "python3.12 -m venv ${workspaceFolder}/backend/.venv"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Python Dependencies (dev)",
            "type": "shell",
            "osx": {
                "command": "${workspaceFolder}/backend/.venv/bin/python -m pip install -e ${workspaceFolder}/backend[dev]"
            },
            "windows": {
                "command": "\"${workspaceFolder}\\backend\\.venv\\Scripts\\python\" -m pip install -e \"${workspaceFolder}\\backend[dev]\""
            },
            "linux": {
                "command": "${workspaceFolder}/backend/.venv/bin/python -m pip install -e ${workspaceFolder}/backend[dev]"
            },
            "problemMatcher": []
        },
        {
            "label": "FastAPI: Run Dev Server",
            "type": "shell",
            "windows": {
                "command": "Set-Location '${workspaceFolder}\\backend'; & '${workspaceFolder}\\backend\\.venv\\Scripts\\python.exe' -m uvicorn app.api.main:app --reload --reload-dir app --port 8000"
            },
            "osx": {
                "command": "cd ${workspaceFolder}/backend && ${workspaceFolder}/backend/.venv/bin/python -m uvicorn app.api.main:app --reload --port 8000"
            },
            "linux": {
                "command": "cd ${workspaceFolder}/backend && ${workspaceFolder}/backend/.venv/bin/python -m uvicorn app.api.main:app --reload --port 8000"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*Started server process.*",
                    "endsPattern": ".*Application startup complete.*"
                }
            }
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "windows": {
                "command": "Set-Location '${workspaceFolder}\\backend'; & '${workspaceFolder}\\backend\\.venv\\Scripts\\python.exe' -m pytest tests -v"
            },
            "osx": {
                "command": "cd ${workspaceFolder}/backend && ${workspaceFolder}/backend/.venv/bin/python -m pytest tests -v"
            },
            "linux": {
                "command": "cd ${workspaceFolder}/backend && ${workspaceFolder}/backend/.venv/bin/python -m pytest tests -v"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run Tests with Coverage",
            "type": "shell",
            "windows": {
                "command": "Set-Location '${workspaceFolder}\\backend'; & '${workspaceFolder}\\backend\\.venv\\Scripts\\python.exe' -m pytest tests --cov=app --cov-report=html --cov-report=term"
            },
            "osx": {
                "command": "cd ${workspaceFolder}/backend && ${workspaceFolder}/backend/.venv/bin/python -m pytest tests --cov=app --cov-report=html --cov-report=term"
            },
            "linux": {
                "command": "cd ${workspaceFolder}/backend && ${workspaceFolder}/backend/.venv/bin/python -m pytest tests --cov=app --cov-report=html --cov-report=term"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run API Tests",
            "type": "shell",
            "windows": {
                "command": "httpyac send \"${workspaceFolder}\\backend\\tests\\api-tests.http\" --all"
            },
            "osx": {
                "command": "httpyac send \"${workspaceFolder}/backend/tests/api-tests.http\" --all"
            },
            "linux": {
                "command": "httpyac send \"${workspaceFolder}/backend/tests/api-tests.http\" --all"
            },
            "dependsOn": ["FastAPI: Run Dev Server"],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
