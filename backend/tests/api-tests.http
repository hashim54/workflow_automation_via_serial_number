###############################################################################
# Workflow Automation via Serial Number - API Tests
#
# API routes:
#   Health
#     GET  /health
#   
#   Config
#     GET  /config/config-status  - Check configuration status
#
#   Workflows
#     POST /api/v1/workflows                  - Execute workflow for a serial number
#     GET  /api/v1/workflows/{serial_number}  - Get workflow status
###############################################################################

@baseUrl      = http://localhost:8000
@serialNumber = SN-12345-TEST

###############################################################################
# HEALTH
###############################################################################

### Health Check
# @name healthCheck
GET {{baseUrl}}/health
Accept: application/json

###############################################################################
# CONFIGURATION STATUS
###############################################################################

### Get Configuration Status
# @name configStatus
GET {{baseUrl}}/config/config-status
Accept: application/json

###############################################################################
# WORKFLOWS — POST /api/v1/workflows
###############################################################################

### Execute Workflow - Upload image file
# @name executeWorkflow
POST {{baseUrl}}/api/v1/workflows
Content-Type: multipart/form-data; boundary=--boundary

----boundary
Content-Disposition: form-data; name="file"; filename="1.jpg"
Content-Type: image/jpeg

< ./images/1.jpg
----boundary--

### Execute Workflow - Missing file (expects 422)
POST {{baseUrl}}/api/v1/workflows
Content-Type: application/json

{}

### Execute Workflow - Unsupported file type (expects 422)
POST {{baseUrl}}/api/v1/workflows
Content-Type: multipart/form-data; boundary=--boundary

----boundary
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./document.pdf
----boundary--

###############################################################################
# WORKFLOWS — GET /api/v1/workflows/{serial_number}
###############################################################################

### Get Workflow Status
# @name getWorkflowStatus
GET {{baseUrl}}/api/v1/workflows/{{serialNumber}}
Accept: application/json

### Get Workflow Status - Non-existent serial number
GET {{baseUrl}}/api/v1/workflows/SN-NOTFOUND-0000
Accept: application/json
