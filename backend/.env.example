# ──────────────────────────────────────────────────────────────────────
# Application Settings
# ──────────────────────────────────────────────────────────────────────
APP_NAME="Workflow Automation API"
ENVIRONMENT=development
DEBUG=false

# ──────────────────────────────────────────────────────────────────────
# Azure App Configuration (optional - for centralized config management)
# ──────────────────────────────────────────────────────────────────────
# When APP_CONFIG_ENDPOINT is set, all other settings can be stored in
# Azure App Configuration. This keeps .env minimal with just bootstrap vars.
# Uses DefaultAzureCredential (managed identity) for authentication.
# APP_CONFIG_ENDPOINT=https://<your-appconfig-store>.azconfig.io
# APP_CONFIG_KEY_FILTER=workflow-automation:*
# APP_CONFIG_LABEL_FILTER=development

# ──────────────────────────────────────────────────────────────────────
# Azure Identity (for service principal auth in dev/test - optional)
# ──────────────────────────────────────────────────────────────────────
# Leave these empty to use DefaultAzureCredential with managed identity
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Cosmos DB Settings (prefix: COSMOS_)
# ──────────────────────────────────────────────────────────────────────
# Use endpoint for managed identity, or connection_string for dev/test
COSMOS_ENDPOINT=
# COSMOS_CONNECTION_STRING=
COSMOS_DATABASE_NAME=workflow-db
COSMOS_CONTAINER_NAME=workflows
# Hierarchical Partition Key paths - matches the data model (user_id -> serial_number)
COSMOS_PARTITION_KEY_PATHS=['/user_id', '/serial_number']
# TTL: automatically expire workflow records after N days
COSMOS_ENABLE_TTL=true
COSMOS_DEFAULT_TTL_DAYS=30

# ──────────────────────────────────────────────────────────────────────
# Blob Storage Settings (prefix: BLOBSTORAGE_)
# ──────────────────────────────────────────────────────────────────────
# Use account_url for managed identity, or connection_string for dev/test
BLOBSTORAGE_ACCOUNT_URL=
# BLOBSTORAGE_CONNECTION_STRING=
BLOBSTORAGE_ARTIFACTS_CONTAINER=artifacts

# ──────────────────────────────────────────────────────────────────────
# Microsoft Foundry Settings (prefix: FOUNDRY_)
# ──────────────────────────────────────────────────────────────────────
# Uses DefaultAzureCredential for authentication
# Two hosted agents required:
#   1. Image Processing Agent - Extracts serial numbers from images
#   2. Reasoning Agent - Analyzes data and provides recommendations
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_IMAGE_PROCESSING_AGENT_ID=
FOUNDRY_REASONING_AGENT_ID=

# Image Processing Agent Settings (deterministic extraction)
FOUNDRY_IMAGE_PROCESSING_MODEL=gpt-5.2

# Reasoning Agent Settings (creative analysis)
FOUNDRY_REASONING_TEMPERATURE=0.3
FOUNDRY_REASONING_MAX_TOKENS=4096

# MAF Observability Settings (see: https://deepwiki.com/microsoft/agent-framework/3.6-observability-and-monitoring)
# ENABLE_SENSITIVE_DATA - Include prompts, tool arguments, and results in traces
# WARNING: Only enable in dev/lab environments - DO NOT use in production with real user data
ENABLE_SENSITIVE_DATA=true

# ──────────────────────────────────────────────────────────────────────
# Application Insights Settings (prefix: APPINSIGHTS_)
# ──────────────────────────────────────────────────────────────────────
APPINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_ENABLED=true
APPINSIGHTS_SAMPLING_PERCENTAGE=100.0

# ──────────────────────────────────────────────────────────────────────
# MCP Client Settings (prefix: MCP_)
# ──────────────────────────────────────────────────────────────────────
# Endpoints for FSG and Phoenix MCP servers via Azure APIM
MCP_FSG_ENDPOINT=
MCP_PHOENIX_ENDPOINT=
MCP_TIMEOUT_SECONDS=30
MCP_MAX_RETRIES=3

# ──────────────────────────────────────────────────────────────────────
# Workflow Execution Settings (prefix: WORKFLOW_)
# ──────────────────────────────────────────────────────────────────────


# ──────────────────────────────────────────────────────────────────────
# API Server Settings (prefix: API_)
# ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_ENABLE_CORS=true
API_ENABLE_DOCS=true

# ──────────────────────────────────────────────────────────────────────
# Azure Key Vault Settings (prefix: KEYVAULT_)
# ──────────────────────────────────────────────────────────────────────
# When KEYVAULT_USE_KEY_VAULT=true, sensitive secrets are resolved from
# Key Vault instead of environment variables.
# Uses DefaultAzureCredential (managed identity) for authentication.
KEYVAULT_URL=https://your-keyvault.vault.azure.net/
KEYVAULT_USE_KEY_VAULT=false
